# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to GitHub.

# The Gmail address that will SEND the emails (can be the doctor's own address)
GMAIL_USER=kumarmukesh82520@gmail.com

# A Gmail "App Password" (NOT your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_16_character_app_password

# The address that should RECEIVE booking emails
DOCTOR_EMAIL=kumarmukesh82520@gmail.com

# Your live frontend URL, once deployed (used for CORS security)
ALLOWED_ORIGIN=https://www.mukeshclinic.com

# Port for local testing (Render/Heroku set this automatically in production)
PORT=5000
